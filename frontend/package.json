{
  "name": "vectis-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "VECTIS — enterprise decision-intelligence console (climate risk vertical).",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host",

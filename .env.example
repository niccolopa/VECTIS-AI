# ─────────────────────────────────────────────────────────────────────────────
# VECTIS environment configuration. Copy to `.env` and adjust.
# Every variable is prefixed VECTIS_ and maps to backend/vectis/core/config.py.
# ─────────────────────────────────────────────────────────────────────────────

# --- Application ---
VECTIS_ENV=development                 # development | production | test
VECTIS_LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
VECTIS_LOG_JSON=false                  # true => structured JSON logs (prod)

# --- API ---
VECTIS_API_HOST=0.0.0.0
VECTIS_API_PORT=8000
VECTIS_CORS_ORIGINS=http://localhost:5173

# --- Database (PostgreSQL + PostGIS) ---
# In docker-compose this resolves to the `db` service. For local SQLite tests
# the test suite overrides this with sqlite:///./test.db automatically.
VECTIS_DATABASE_URL=postgresql+psycopg://vectis:vectis@db:5432/vectis

# --- LLM provider ---
# mock  => deterministic, no network, no key (default; used in CI & demos)
# claude => Anthropic API (requires VECTIS_ANTHROPIC_API_KEY)
VECTIS_LLM_PROVIDER=mock
VECTIS_ANTHROPIC_API_KEY=
VECTIS_LLM_MODEL=claude-opus-4-8
VECTIS_LLM_FAST_MODEL=claude-haiku-4-5

# --- Real-time connectors ---
# NASA FIRMS MAP_KEY for live active-fire data (free: https://firms.modaps.eosdis.nasa.gov/api/).
# Empty => the satellite connector serves deterministic offline detections (clone-safe).
VECTIS_FIRMS_API_KEY=

# Per-source base URLs — each defaults to the real upstream. Point one at the optional
# internal Sluice gateway instead to route that source through it (no other code change).
VECTIS_FIRMS_BASE_URL=https://firms.modaps.eosdis.nasa.gov
VECTIS_USGS_BASE_URL=https://earthquake.usgs.gov
VECTIS_GDACS_BASE_URL=https://www.gdacs.org
# Historical ERA5 reanalysis for calibration: Open-Meteo's keyless archive API.
VECTIS_ERA5_BASE_URL=https://archive-api.open-meteo.com
# Sluice-only: FIRMS MAP_KEY pool the gateway fails over across (comma-separated).
# Empty => falls back to the single VECTIS_FIRMS_API_KEY. Not a quota-evasion pool.
VECTIS_SLUICE_FIRMS_KEYS=

# --- Data / ML ---
VECTIS_DATA_DIR=./data
VECTIS_ARTIFACTS_DIR=./backend/artifacts
VECTIS_RANDOM_SEED=42

# --- Agents ---
VECTIS_CRITIC_MAX_REVISIONS=1          # bounded Critic revision loop
# Orchestration engine: custom (default, deterministic, no extra deps) | langgraph
VECTIS_ORCHESTRATOR=custom

# --- Real-time state & streaming backends ---
# In-process by default, so a fresh clone runs with zero external infrastructure.
# Set to 'redis' (with a reachable VECTIS_REDIS_URL) for multi-process / scaled deploys.
VECTIS_STATE_BACKEND=memory            # memory | redis  (WorldCellState store)
VECTIS_BROKER=memory                   # memory | redis  (event-stream broker)
VECTIS_REDIS_URL=redis://localhost:6379/0
VECTIS_GLOBAL_INGESTION=1              # 1 => run the global ingestion loop; 0 disables it

# --- Tiering / compute budgets (per cycle) ---
# Hard caps that bound how much heavy compute runs each cycle — the cost firewall.
VECTIS_MAX_T1_PER_CYCLE=64            # max full Monte Carlo + Bayesian deep-analysis runs
VECTIS_MAX_T2_PER_CYCLE=5            # max board/LLM narrations (alias: VECTIS_MAX_BOARD_REPORTS_PER_CYCLE)
VECTIS_WATCHLIST_REFRESH_CYCLES=3    # guarantee a pinned cell a T1 slot every Nth cycle
VECTIS_T1_ITERATIONS=2000            # Monte Carlo scenarios per T1 deep analysis

# --- Durable history retention (Session 39) ---
VECTIS_HISTORY_FINE_DAYS=7           # keep fine-grained cell snapshots this many days
VECTIS_HISTORY_ROLLUP_DAYS=90        # keep hourly roll-ups this many days, then prune

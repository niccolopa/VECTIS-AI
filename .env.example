# ─────────────────────────────────────────────────────────────────────────────
# VECTIS environment configuration. Copy to `.env` and adjust.
# Every variable is prefixed VECTIS_ and maps to backend/vectis/core/config.py.
# ─────────────────────────────────────────────────────────────────────────────

# --- Application ---
VECTIS_ENV=development                 # development | production | test
VECTIS_LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
VECTIS_LOG_JSON=false                  # true => structured JSON logs (prod)

# --- API ---
VECTIS_API_HOST=0.0.0.0
VECTIS_API_PORT=8000
VECTIS_CORS_ORIGINS=http://localhost:5173

# --- Database (PostgreSQL + PostGIS) ---
# In docker-compose this resolves to the `db` service. For local SQLite tests
# the test suite overrides this with sqlite:///./test.db automatically.
VECTIS_DATABASE_URL=postgresql+psycopg://vectis:vectis@db:5432/vectis

# --- LLM provider ---
# mock  => deterministic, no network, no key (default; used in CI & demos)
# claude => Anthropic API (requires VECTIS_ANTHROPIC_API_KEY)
VECTIS_LLM_PROVIDER=mock
VECTIS_ANTHROPIC_API_KEY=
VECTIS_LLM_MODEL=claude-opus-4-8
VECTIS_LLM_FAST_MODEL=claude-haiku-4-5

# --- Real-time connectors ---
# NASA FIRMS MAP_KEY for live active-fire data (free: https://firms.modaps.eosdis.nasa.gov/api/).
# Empty => the satellite connector serves deterministic offline detections (clone-safe).
VECTIS_FIRMS_API_KEY=

# --- Data / ML ---
VECTIS_DATA_DIR=./data
VECTIS_ARTIFACTS_DIR=./backend/artifacts
VECTIS_RANDOM_SEED=42

# --- Agents ---
VECTIS_CRITIC_MAX_REVISIONS=1          # bounded Critic revision loop
# Orchestration engine: custom (default, deterministic, no extra deps) | langgraph
VECTIS_ORCHESTRATOR=custom
